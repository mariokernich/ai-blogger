{
    "name": "sap-ai-news",
    "version": "1.0.0",
    "description": "Automated AI-generated blog for SAP fullstack developers (UI5, RAP, BTP, ABAP, Fiori)",
    "type": "module",
    "private": true,
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "collect": "tsx src/index.ts collect",
        "generate": "tsx src/index.ts generate",
        "run": "tsx src/index.ts run",
        "run:dry": "tsx src/index.ts run --dry-run",
        "lint": "eslint . --ext .ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "debug": "tsx src/debug/cli.ts"
    },
    "engines": {
        "node": ">=20"
    },
    "dependencies": {
        "dotenv": "^16.4.5",
        "fast-xml-parser": "^4.5.0",
        "openai": "^4.67.3",
        "sharp": "^0.33.5"
    },
    "devDependencies": {
        "@types/node": "^22.7.5",
        "@vitest/ui": "^2.1.3",
        "tsx": "^4.19.1",
        "typescript": "^5.6.3",
        "vitest": "^2.1.3"
    }
}
