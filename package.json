{
  "name": "sap-ai-news",
  "version": "1.0.0",
  "description": "Automated AI-generated blog for SAP fullstack developers (UI5, RAP, BTP, ABAP, Fiori)",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "collect": "tsx src/index.ts collect",
    "generate": "tsx src/index.ts generate",
    "run": "tsx src/index.ts run",
    "run:dry": "tsx src/index.ts run --dry-run",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "debug": "tsx src/debug/cli.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "17.4.2",
    "fast-xml-parser": "5.9.3",
    "openai": "6.45.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "@vitest/ui": "4.1.9",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}