# ===== OpenAI-compatible API (text + image) =====
OPENAI_API_KEY=sk-your-key-here
# Base URL of your OpenAI-compatible endpoint (default: official OpenAI)
OPENAI_BASE_URL=https://api.openai.com/v1
# Text model used to write the article + LinkedIn post
OPENAI_TEXT_MODEL=gpt-4o
# Image model used to create thumbnails
OPENAI_IMAGE_MODEL=gpt-image-1

# ===== GitHub =====
# Token used for GitHub API calls (repos/commits). In Actions use the built-in GITHUB_TOKEN.
GITHUB_TOKEN=ghp_your_token_here

# ===== LinkedIn (optional auto-publish) =====
# OAuth access token with w_member_social scope
LINKEDIN_ACCESS_TOKEN=
# Author URN, e.g. "urn:li:person:xxxx" or "urn:li:organization:xxxx"
LINKEDIN_AUTHOR_URN=

# ===== Blog config =====
# Public base URL where the blog is hosted (used for LinkedIn link)
BLOG_BASE_URL=https://your-username.github.io/sap-ai-news
