# ===== OpenAI-compatible API (text + image) =====
OPENAI_API_KEY=sk-your-key-here
# Base URL of your OpenAI-compatible endpoint (default: official OpenAI)
OPENAI_BASE_URL=https://api.openai.com/v1
# Text model used to write the article + LinkedIn post
# Recommended best quality: gpt-5.5-pro (alt: bedrock-anthropic-claude-opus-4.8, gpt-5.5)
OPENAI_TEXT_MODEL=gpt-4o
# Image model used to create thumbnails.
# NOTE: gpt-image-1 / dall-e-3 may be geo-restricted on some EU proxies.
# Recommended EU-safe best quality: vertex-imagen-4-ultra (alt: flux-11-pro, but it
# rejects 1536x1024 — use a smaller size). Set OPENAI_IMAGE_ENABLED=false for a
# branded placeholder with no API call.
OPENAI_IMAGE_MODEL=gpt-image-1
# Set to "false" to skip AI image generation and use a branded placeholder.
OPENAI_IMAGE_ENABLED=true

# ===== GitHub =====
# Token used for GitHub API calls (repos/commits). In Actions use the built-in GITHUB_TOKEN.
GITHUB_TOKEN=ghp_your_token_here

# ===== LinkedIn (optional auto-publish) =====
# OAuth access token with w_member_social scope
LINKEDIN_ACCESS_TOKEN=
# Author URN, e.g. "urn:li:person:xxxx" or "urn:li:organization:xxxx"
LINKEDIN_AUTHOR_URN=

# ===== Blog config =====
# Public base URL where the blog is hosted (used for LinkedIn link)
BLOG_BASE_URL=https://your-username.github.io/sap-ai-news
